# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/patient_booking
# For MongoDB Atlas:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/patient_booking

# JWT Secret (change this to a long random string in production)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# Session Secret
SESSION_SECRET=your_session_secret_key_change_this_in_production

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173
